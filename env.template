# Space-Track API Credentials Template
# 
# Register for a free account at https://www.space-track.org/auth/createAccount
# 
# Instructions:
# 1. Copy this file to .env in the project root:
#    cp env.template .env
# 2. Replace the placeholder values with your actual Space-Track credentials
# 3. The .env file is automatically ignored by git to keep your credentials secure
#
# SPACE_TRACK_ID is your Space-Track username
# SPACE_TRACK_PASSWORD is your Space-Track password

SPACE_TRACK_ID=your_username_here
SPACE_TRACK_PASSWORD=your_password_here

